Package: PhageProbioticSynergy
Title: Phage-Probiotic Synergy Platform for Animal Health
Version: 0.1.0
Authors@R: 
    c(person(given = "Jinlong", family = "Zhang", email = "jinlong@gdou.edu.cn", role = c("aut", "cre")))
